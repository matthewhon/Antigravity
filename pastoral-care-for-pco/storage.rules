rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Email media uploads ──────────────────────────────────────────────────
    // Allow authenticated users to read/write email images and files.
    // Files are scoped to the church via filename prefix (uploaded by the app).

    match /email_images/{fileName} {
      allow read: if true;                         // Public read (needed for email recipients)
      allow write: if request.auth != null         // Must be signed in
                   && request.resource.size < 10 * 1024 * 1024  // Max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    match /email_files/{fileName} {
      allow read: if true;                         // Public read (email recipients click downloads)
      allow write: if request.auth != null         // Must be signed in
                   && request.resource.size < 50 * 1024 * 1024; // Max 50 MB
    }

    // ─── Tenant File Storage (GCS) ───────────────────────────────────────────
    match /tenants/{churchId}/uploads/{fileName} {
      allow read: if true; // Public read so URLs work in SMS / Emails, or we can restrict if using proxy
      allow write: if request.auth != null;
    }

    // ─── MMS Media Uploads ───────────────────────────────────────────────────
    match /mms/{churchId}/{fileName} {
      allow read: if true; // Public read so Twilio can download the attachment
      allow write: if request.auth != null;
    }

    // ─── SMS Inbox/Workflow Media Uploads ─────────────────────────────────────
    match /sms-media/{churchId}/{allPaths=**} {
      allow read: if true; // Public read so Twilio can download the attachment
      allow write: if request.auth != null;
    }

    // ─── Church Logos ────────────────────────────────────────────────────────
    match /church_logos/{churchId}/{fileName} {
      allow read: if true; // Public read so logos display on forms
      allow write: if request.auth != null;
    }

    // ─── Public Form File Uploads ────────────────────────────────────────────
    match /form_uploads/{churchId}/{formId}/{fileName} {
      allow read: if true; // Allow reading form uploads
      allow write: if true // Allow public write for form submissions
                   && request.resource.size < 25 * 1024 * 1024; // Max 25 MB
    }

    // ─── All other paths blocked by default ──────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
